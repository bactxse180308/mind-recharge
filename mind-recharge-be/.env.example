# ============================================================
# Mind Recharge Backend — Environment Variables Template
# ============================================================
# Sao chép file này thành .env và điền giá trị thực trước khi chạy app
# ============================================================

# ── Server ──────────────────────────────────────────────────
SERVER_PORT=8080

# ── Database (Microsoft SQL Server) ─────────────────────────
DB_USER=sa
DB_PASS=YOUR_DB_PASSWORD_HERE

# ── JWT ──────────────────────────────────────────────────────
# Secret phải >= 256-bit (>= 32 ký tự ngẫu nhiên)
JWT_SECRET=CHANGE_ME_TO_A_STRONG_SECRET_AT_LEAST_32_CHARS
# Access token hết hạn sau 15 phút (ms)
JWT_ACCESS_EXPIRY_MS=900000
# Refresh token hết hạn sau 30 ngày
JWT_REFRESH_EXPIRY_DAYS=30

# ── CORS ─────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost,https://localhost,capacitor://localhost

# ── Admin seed account ───────────────────────────────────────
ADMIN_EMAIL=admin@mindrecharge.com
ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD
ADMIN_FULL_NAME=System Administrator
ADMIN_PHONE=0123456789
ADMIN_ADDRESS=System
